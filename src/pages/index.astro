<script>
  // ── Nav scroll effect ──────────────────────────────────────────────────
  const nav = document.getElementById('main-nav') as HTMLElement;
  let lastScroll = 0;

  function updateNav() {
    const y = window.scrollY;
    if (y > 60) {
      nav.classList.remove('nav-transparent');
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.add('nav-transparent');
      nav.classList.remove('nav-scrolled');
    }
    lastScroll = y;
  }

  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // ── FAQ accordion ──────────────────────────────────────────────────────
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const icon = item.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';

      // Close all
      document.querySelectorAll('.faq-answer').forEach((a: Element) => { (a as HTMLElement).style.maxHeight = '0px'; });
      document.querySelectorAll('.faq-icon').forEach((ic: Element) => { (ic as HTMLElement).style.transform = ''; });

      if (!isOpen) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>

