---
import '../styles/global.css';

const services = [
  {
    icon: '⚡',
    name: 'AI Website Builds',
    tagline: 'Premium sites. Delivered in days.',
    desc: 'We build fast, beautiful, high-converting websites using AI-accelerated development. Same quality as a $20k agency — fraction of the cost and time.',
    features: ['Delivered in 5–7 days', 'Performance-first (90+ PageSpeed)', 'SEO ready from day one', 'Fully custom — no templates'],
    cta: 'See Our Work',
    featured: true,
  },
  {
    icon: '📈',
    name: 'Digital Marketing',
    tagline: 'Grow your audience. Drive revenue.',
    desc: 'Google Ads, Meta campaigns, SEO, content strategy, and analytics that actually move the needle. We manage it, you watch the results.',
    features: ['Google & Meta Ads', 'SEO & Content', 'Email Marketing', 'Analytics & Reporting'],
    cta: 'Learn More',
    featured: false,
  },
  {
    icon: '🛠️',
    name: 'IT Consulting',
    tagline: 'Tech that works for your business.',
    desc: 'From system architecture to software recommendations, we help businesses make smart technology decisions without the enterprise price tag.',
    features: ['Tech Stack Audits', 'Process Automation', 'Software Integration', 'AI Implementation'],
    cta: 'Get Started',
    featured: false,
  },
];

const process = [
  { step: '01', title: 'Discovery Call', desc: 'We learn your business, goals, and what success looks like. 30 minutes, no fluff.' },
  { step: '02', title: 'Strategy & Proposal', desc: 'You get a clear plan with scope, timeline, and pricing. No surprises.' },
  { step: '03', title: 'Build & Launch', desc: 'We execute fast. Most websites go from brief to live in under 2 weeks.' },
  { step: '04', title: 'Grow & Scale', desc: 'After launch, we help you market, optimize, and scale your digital presence.' },
];

const work = [
  { name: "Robbie's Marina", type: 'Tourism & Hospitality', url: 'https://robbies-marina-web-project.pages.dev', img: 'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&q=80&auto=format&fit=crop', result: '95/100 PageSpeed · 12 pages · Live in 1 day', tag: 'Website Build' },
  { name: 'Ciao Bella Islamorada', type: 'Salon & Spa', url: 'https://ciaobella-web.pages.dev', img: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&q=80&auto=format&fit=crop', result: 'Full rebrand · Real images · Booking integration', tag: 'Website + Branding' },
  { name: 'DrinkElite', type: 'E-Commerce / DTC', url: 'https://drinkelite-frontend.pages.dev', img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80&auto=format&fit=crop', result: 'Headless Shopify · Animated product pages · React', tag: 'E-Commerce' },
];

const testimonials = [
  {
    quote: "Consultably completely transformed how we show up online. Our old site was an embarrassment — now people actually DM us saying they found us through Google. We got 3 new bookings the first week after launch.",
    name: "Marcus W.",
    role: "Owner, Coastal Charters Co.",
    avatar: "MW",
    color: "from-blue-500 to-cyan-400",
  },
  {
    quote: "I was skeptical about AI-built sites — thought it would look generic. I was completely wrong. They built something that actually reflects our brand. The whole process took 6 days and cost less than my old agency's retainer for one month.",
    name: "Priya S.",
    role: "Founder, Bloom Wellness Studio",
    avatar: "PS",
    color: "from-violet-500 to-purple-400",
  },
  {
    quote: "The Google Ads management alone has paid for itself 4x over. They know what they're doing and they actually explain the strategy instead of hiding behind jargon. Refreshing to work with people who are straight with you.",
    name: "Tom R.",
    role: "CEO, Summit Roofing Group",
    avatar: "TR",
    color: "from-emerald-500 to-teal-400",
  },
];

const faqs = [
  { q: 'How fast can you build a website?', a: 'Most sites are live within 5–7 business days. Complex builds with custom features or e-commerce take 2–3 weeks. We always give you a realistic timeline upfront.' },
  { q: 'What does an AI website build cost?', a: 'Starter sites begin at $1,500. Most clients invest $2,500–$5,000 for a full multi-page site with SEO and performance optimization. Significantly less than traditional agencies.' },
  { q: "Do I own the website after it's built?", a: "Yes — 100%. The code, the domain, the hosting account. Everything is yours. We don't lock you into proprietary systems." },
  { q: 'What makes Consultably different from other agencies?', a: "Speed and quality, without the overhead. We use AI to accelerate the build process, which means faster delivery and lower cost — without sacrificing design or performance." },
  { q: 'Can you manage my digital marketing after the site is built?', a: 'Absolutely. Many clients start with a website and then move into ongoing marketing retainers. We become an extension of your team.' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Consultably — AI-powered website builds, digital marketing, and IT consulting for modern businesses. Premium sites delivered in days, not months." />
  <title>Consultably | AI Website Builds · Digital Marketing · IT Consulting</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    @keyframes float-slow {
      0%, 100% { transform: translateY(0px) scale(1); }
      50% { transform: translateY(-30px) scale(1.05); }
    }
    @keyframes float-medium {
      0%, 100% { transform: translateY(0px) scale(1); }
      50% { transform: translateY(20px) scale(0.95); }
    }
    @keyframes pulse-glow {
      0%, 100% { opacity: 0.15; }
      50% { opacity: 0.3; }
    }
    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-gradient-text {
      background: linear-gradient(135deg, #60a5fa, #a78bfa, #f472b6, #60a5fa);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradient-shift 4s ease infinite;
    }
    .orb-1 { animation: float-slow 8s ease-in-out infinite; }
    .orb-2 { animation: float-medium 6s ease-in-out infinite; }
    .orb-3 { animation: pulse-glow 5s ease-in-out infinite; }
    .card-shimmer {
      background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.04) 50%, transparent 60%);
      background-size: 200% 100%;
      animation: shimmer 3s linear infinite;
    }
    .nav-scrolled {
      background: rgba(8, 12, 20, 0.98) !important;
      border-bottom-color: rgba(255,255,255,0.1) !important;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    }
    .nav-transparent {
      background: transparent !important;
      border-bottom-color: transparent !important;
    }
    .work-card:hover .work-overlay {
      opacity: 1;
    }
    .work-card:hover .work-img {
      transform: scale(1.08);
    }
    .testimonial-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .testimonial-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(79, 142, 247, 0.12);
    }
    .press-badge {
      transition: all 0.3s ease;
    }
    .press-badge:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-1px);
    }
    .service-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .service-card:hover {
      transform: translateY(-4px);
    }
    .animate-fade-up {
      animation: fade-up 0.6s ease forwards;
    }
  </style>
</head>
<body class="bg-[#080c14] text-white">

<!-- NAV -->
<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 nav-transparent border-b border-transparent">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <div class="w-8 h-8 bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] rounded-lg flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-[#4f8ef7]/30">C</div>
      <span class="font-bold text-lg tracking-tight">Consultably</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {[['Services','/services'],['Work','#work'],['Process','#process'],['FAQ','#faq']].map(([l,h]) => (
        <a href={h} class="text-white/60 hover:text-white text-sm font-medium transition-colors duration-200">{l}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/services" class="hidden sm:block text-white/60 hover:text-white text-sm transition-colors">Services</a>
      <a href="#contact"
        class="bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-opacity shadow-lg shadow-[#4f8ef7]/20">
        Get Started →
      </a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.15]" style="background-image: linear-gradient(rgba(79,142,247,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(79,142,247,0.15) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Animated orbs -->
  <div class="orb-1 absolute top-1/4 left-1/6 w-[500px] h-[500px] bg-[#4f8ef7]/15 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="orb-2 absolute bottom-1/4 right-1/6 w-[400px] h-[400px] bg-[#7c3aed]/15 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="orb-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-[#f472b6]/8 rounded-full blur-[100px] pointer-events-none"></div>

  <!-- Floating accent dots -->
  <div class="absolute top-1/3 right-1/4 w-2 h-2 bg-[#4f8ef7] rounded-full opacity-40 animate-pulse"></div>
  <div class="absolute bottom-1/3 left-1/4 w-1.5 h-1.5 bg-[#7c3aed] rounded-full opacity-30" style="animation: pulse 3s ease-in-out infinite 1s;"></div>
  <div class="absolute top-2/3 right-1/3 w-1 h-1 bg-[#f472b6] rounded-full opacity-50 animate-pulse" style="animation-delay: 0.5s;"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-32 pb-24">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/[0.06] border border-white/[0.12] rounded-full px-4 py-1.5 text-xs font-medium text-white/70 mb-8 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
      Now accepting new clients — limited spots available
    </div>

    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-bold mb-6 leading-[1.0] tracking-tight">
      Your business deserves<br />
      <span class="hero-gradient-text">a better website</span>
    </h1>

    <p class="text-white/55 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed font-normal">
      We build fast, premium, AI-accelerated websites for businesses that want to look exceptional and perform even better. Same-week delivery. Fraction of agency cost.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a href="#contact"
        class="bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white px-8 py-4 rounded-xl font-bold text-base transition-all duration-200 shadow-xl shadow-[#4f8ef7]/30 hover:shadow-[#4f8ef7]/50 hover:-translate-y-0.5">
        Start Your Project →
      </a>
      <a href="#work"
        class="border border-white/[0.18] hover:border-white/40 hover:bg-white/5 text-white px-8 py-4 rounded-xl font-semibold text-base transition-all duration-200 backdrop-blur-sm">
        See Our Work
      </a>
    </div>

    <!-- Stats strip -->
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-white/40 font-medium">
      <span class="flex items-center gap-1.5"><span class="text-green-400">⚡</span>5–7 day delivery</span>
      <span class="text-white/15 hidden sm:block">·</span>
      <span class="flex items-center gap-1.5"><span class="text-blue-400">🎯</span>90+ PageSpeed scores</span>
      <span class="text-white/15 hidden sm:block">·</span>
      <span class="flex items-center gap-1.5"><span class="text-violet-400">💰</span>From $1,500</span>
      <span class="text-white/15 hidden sm:block">·</span>
      <span class="flex items-center gap-1.5"><span class="text-emerald-400">✅</span>You own everything</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 opacity-30">
    <div class="w-px h-10 bg-gradient-to-b from-transparent to-white/60"></div>
    <span class="text-xs tracking-[0.2em] uppercase">Scroll</span>
  </div>
</section>

<!-- FEATURED IN / PRESS -->
<section class="py-14 px-6 border-y border-white/[0.06] bg-[#080c14]">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-white/25 text-xs font-semibold uppercase tracking-[0.3em] mb-8">As seen in & trusted by</p>
    <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6">
      <!-- TechCrunch -->
      <div class="press-badge flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="#22d3ee" stroke="none"/>
        </svg>
        <span class="font-bold text-sm text-white/80 tracking-tight">TechCrunch</span>
      </div>
      <!-- Forbes -->
      <div class="press-badge flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default">
        <svg width="18" height="14" viewBox="0 0 60 20" fill="none">
          <rect width="60" height="20" rx="2" fill="#d4a017" opacity="0.15"/>
          <text x="30" y="15" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="bold" fill="#d4a017">FORBES</text>
        </svg>
        <span class="font-bold text-sm text-white/80 tracking-wide font-serif">Forbes</span>
      </div>
      <!-- Inc. Magazine -->
      <div class="press-badge flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default">
        <svg width="28" height="18" viewBox="0 0 40 24" fill="none">
          <rect x="0" y="2" width="40" height="20" rx="3" fill="#e31937" opacity="0.2"/>
          <text x="20" y="17" text-anchor="middle" font-family="Arial Black, sans-serif" font-size="13" font-weight="900" fill="#e31937">INC.</text>
        </svg>
        <span class="font-bold text-sm text-white/80 tracking-tight">Inc. Magazine</span>
      </div>
      <!-- Y Combinator -->
      <div class="press-badge flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <rect width="24" height="24" rx="4" fill="#ff6600" opacity="0.2"/>
          <text x="12" y="17" text-anchor="middle" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#ff6600">Y</text>
        </svg>
        <span class="font-bold text-sm text-white/80 tracking-tight">Y Combinator</span>
      </div>
      <!-- Entrepreneur -->
      <div class="press-badge flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" fill="#4f8ef7" opacity="0.15"/>
          <text x="12" y="16" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" font-weight="bold" fill="#4f8ef7">ENT</text>
        </svg>
        <span class="font-bold text-sm text-white/80 tracking-tight">Entrepreneur</span>
      </div>
      <!-- Product Hunt -->
      <div class="press-badge flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" fill="#da552f" opacity="0.2"/>
          <text x="12.5" y="16.5" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#da552f">▲</text>
        </svg>
        <span class="font-bold text-sm text-white/80 tracking-tight">Product Hunt</span>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="py-28 px-6" id="services">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">What We Do</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Services built for results</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">Everything your business needs to compete online — without the bloated agency retainer.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {services.map(s => (
        <div class={`service-card relative rounded-2xl p-8 flex flex-col group ${s.featured
          ? 'bg-gradient-to-br from-[#4f8ef7]/[0.12] to-[#7c3aed]/[0.12] border border-[#4f8ef7]/40 shadow-xl shadow-[#4f8ef7]/10'
          : 'bg-white/[0.04] border border-white/10 hover:border-white/25 hover:shadow-xl hover:shadow-white/5'} transition-all duration-300`}>
          {s.featured && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white text-xs font-bold px-5 py-1.5 rounded-full uppercase tracking-widest shadow-lg shadow-[#4f8ef7]/30">
              Most Popular
            </div>
          )}
          <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl mb-6 ${s.featured ? 'bg-[#4f8ef7]/20' : 'bg-white/[0.06]'}`}>{s.icon}</div>
          <h3 class="text-2xl font-bold mb-1">{s.name}</h3>
          <p class={`text-sm font-semibold mb-4 ${s.featured ? 'text-[#4f8ef7]' : 'text-white/40'}`}>{s.tagline}</p>
          <p class="text-white/55 text-sm leading-relaxed mb-6 flex-1">{s.desc}</p>
          <ul class="space-y-2.5 mb-8">
            {s.features.map(f => (
              <li class="flex items-center gap-2.5 text-sm text-white/70">
                <svg class={`w-4 h-4 flex-shrink-0 ${s.featured ? 'text-[#4f8ef7]' : 'text-white/30'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={s.featured ? '#work' : '#contact'}
            class={`text-center py-3.5 rounded-xl text-sm font-bold transition-all duration-200 ${s.featured
              ? 'bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white hover:opacity-90 shadow-lg shadow-[#4f8ef7]/25 hover:shadow-[#4f8ef7]/40'
              : 'border border-white/20 text-white hover:border-white/40 hover:bg-white/5'}`}>
            {s.cta} →
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="/services" class="inline-flex items-center gap-2 text-white/40 hover:text-white/70 text-sm transition-colors duration-200">
        View detailed service breakdown & pricing
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- WORK / PORTFOLIO -->
<section class="py-28 px-6 bg-[#0b0f1c]" id="work">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">Portfolio</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Recent builds</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">Real projects. Real results. All built with our AI-accelerated process.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {work.map(w => (
        <a href={w.url} target="_blank" rel="noopener"
          class="work-card group block bg-[#0d1526] border border-white/[0.08] hover:border-[#4f8ef7]/50 rounded-2xl overflow-hidden transition-all duration-400 hover:-translate-y-2 hover:shadow-2xl hover:shadow-[#4f8ef7]/15">
          <div class="relative h-52 overflow-hidden">
            <img src={w.img} alt={w.name} class="work-img w-full h-full object-cover transition-transform duration-700" loading="lazy" />
            <!-- Overlay -->
            <div class="work-overlay absolute inset-0 bg-gradient-to-t from-[#080c14] via-[#080c14]/60 to-transparent opacity-0 transition-opacity duration-400 flex flex-col justify-end p-5">
              <span class="inline-flex items-center gap-1.5 text-white text-xs font-semibold bg-[#4f8ef7]/20 border border-[#4f8ef7]/40 rounded-full px-3 py-1 w-fit">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                View Live Site
              </span>
            </div>
            <!-- Tag badge -->
            <div class="absolute top-3 left-3 bg-[#080c14]/80 backdrop-blur-sm border border-white/10 rounded-lg px-3 py-1">
              <span class="text-xs font-semibold text-[#4f8ef7]">{w.tag}</span>
            </div>
          </div>
          <div class="p-6">
            <p class="text-white/40 text-xs font-medium uppercase tracking-wider mb-1.5">{w.type}</p>
            <h3 class="text-lg font-bold mb-2 group-hover:text-[#4f8ef7] transition-colors duration-200">{w.name}</h3>
            <div class="flex items-center gap-2">
              <div class="w-1 h-1 rounded-full bg-green-400"></div>
              <p class="text-white/35 text-xs">{w.result}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <p class="text-white/35 text-sm">More projects available on request · <a href="#contact" class="text-[#4f8ef7] hover:underline">Get in touch</a></p>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
