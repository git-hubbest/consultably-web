---
import '../styles/global.css';

const services = [
  {
    icon: '⚡',
    name: 'AI Website Builds',
    tagline: 'Premium sites. Delivered in days.',
    desc: 'We build fast, beautiful, high-converting websites using AI-accelerated development. Same quality as a $20k agency — fraction of the cost and time.',
    features: ['Delivered in 5–7 days', 'Performance-first (90+ PageSpeed)', 'SEO ready from day one', 'Fully custom — no templates'],
    cta: 'See Our Work',
    featured: true,
  },
  {
    icon: '📈',
    name: 'Digital Marketing',
    tagline: 'Grow your audience. Drive revenue.',
    desc: 'Google Ads, Meta campaigns, SEO, content strategy, and analytics that actually move the needle. We manage it, you watch the results.',
    features: ['Google & Meta Ads', 'SEO & Content', 'Email Marketing', 'Analytics & Reporting'],
    cta: 'Learn More',
    featured: false,
  },
  {
    icon: '🛠️',
    name: 'IT Consulting',
    tagline: 'Tech that works for your business.',
    desc: 'From system architecture to software recommendations, we help businesses make smart technology decisions without the enterprise price tag.',
    features: ['Tech Stack Audits', 'Process Automation', 'Software Integration', 'AI Implementation'],
    cta: 'Get Started',
    featured: false,
  },
];

const process = [
  { step: '01', title: 'Discovery Call', desc: 'We learn your business, goals, and what success looks like. 30 minutes, no fluff.' },
  { step: '02', title: 'Strategy & Proposal', desc: 'You get a clear plan with scope, timeline, and pricing. No surprises.' },
  { step: '03', title: 'Build & Launch', desc: 'We execute fast. Most websites go from brief to live in under 2 weeks.' },
  { step: '04', title: 'Grow & Scale', desc: 'After launch, we help you market, optimize, and scale your digital presence.' },
];

const work = [
  { name: "Robbie's Marina", type: 'Tourism & Hospitality', url: 'https://robbies-marina-web-project.pages.dev', img: 'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&q=80&auto=format&fit=crop', result: '95/100 PageSpeed · 12 pages · Live in 1 day' },
  { name: 'Ciao Bella Islamorada', type: 'Salon & Spa', url: 'https://ciaobella-web.pages.dev', img: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&q=80&auto=format&fit=crop', result: 'Full rebrand · Real images · Booking integration' },
  { name: 'DrinkElite', type: 'E-Commerce / DTC', url: 'https://drinkelite-frontend.pages.dev', img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80&auto=format&fit=crop', result: 'Headless Shopify · Animated product pages · React' },
];

const faqs = [
  { q: 'How fast can you build a website?', a: 'Most sites are live within 5–7 business days. Complex builds with custom features or e-commerce take 2–3 weeks. We always give you a realistic timeline upfront.' },
  { q: 'What does an AI website build cost?', a: 'Starter sites begin at $1,500. Most clients invest $2,500–$5,000 for a full multi-page site with SEO and performance optimization. Significantly less than traditional agencies.' },
  { q: 'Do I own the website after it\'s built?', a: 'Yes — 100%. The code, the domain, the hosting account. Everything is yours. We don\'t lock you into proprietary systems.' },
  { q: 'What makes Consultably different from other agencies?', a: 'Speed and quality, without the overhead. We use AI to accelerate the build process, which means faster delivery and lower cost — without sacrificing design or performance.' },
  { q: 'Can you manage my digital marketing after the site is built?', a: 'Absolutely. Many clients start with a website and then move into ongoing marketing retainers. We become an extension of your team.' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Consultably — AI-powered website builds, digital marketing, and IT consulting for modern businesses. Premium sites delivered in days, not months." />
  <title>Consultably | AI Website Builds · Digital Marketing · IT Consulting</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-[#080c14] text-white">

<!-- NAV -->
<header class="fixed top-0 left-0 right-0 z-50 bg-[#080c14]/90 backdrop-blur-md border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] rounded-lg flex items-center justify-center text-white font-bold text-sm">C</div>
      <span class="font-bold text-lg tracking-tight">Consultably</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {[['Services','#services'],['Work','#work'],['Process','#process'],['FAQ','#faq']].map(([l,h]) => (
        <a href={h} class="text-white/60 hover:text-white text-sm font-medium transition-colors">{l}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="#contact" class="hidden sm:block text-white/60 hover:text-white text-sm transition-colors">Sign In</a>
      <a href="#contact"
        class="bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white px-5 py-2 rounded-lg text-sm font-semibold transition-opacity">
        Get Started
      </a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(rgba(79,142,247,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(79,142,247,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <!-- Glow orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#4f8ef7]/20 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-[#7c3aed]/20 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 text-xs font-medium text-white/70 mb-7">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
      AI-Powered Website Builds — Delivered in Days
    </div>

    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-[1.0] tracking-tight">
      Your business deserves<br />
      <span class="bg-gradient-to-r from-[#4f8ef7] via-[#a78bfa] to-[#7c3aed] bg-clip-text text-transparent">
        a better website
      </span>
    </h1>

    <p class="text-white/60 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
      We build fast, premium, AI-accelerated websites for businesses that want to look exceptional and perform even better. Same-week delivery. Fraction of agency cost.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a href="#contact"
        class="bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white px-8 py-4 rounded-lg font-bold text-base transition-opacity shadow-lg shadow-[#4f8ef7]/25">
        Start Your Project →
      </a>
      <a href="#work"
        class="border border-white/20 hover:border-white/40 text-white px-8 py-4 rounded-lg font-semibold text-base transition-colors">
        See Our Work
      </a>
    </div>

    <!-- Social proof -->
    <div class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-sm text-white/40 font-medium">
      <span>⚡ 5–7 day delivery</span>
      <span>🎯 90+ PageSpeed scores</span>
      <span>💰 From $1,500</span>
      <span>✅ You own everything</span>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="py-24 px-6" id="services">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">What We Do</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Services built for results</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">Everything your business needs to compete online — without the bloated agency retainer.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {services.map(s => (
        <div class={`relative rounded-2xl p-8 flex flex-col ${s.featured
          ? 'bg-gradient-to-br from-[#4f8ef7]/20 to-[#7c3aed]/20 border border-[#4f8ef7]/40'
          : 'bg-white/4 border border-white/10 hover:border-white/20'} transition-all duration-300`}>
          {s.featured && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest">
              Most Popular
            </div>
          )}
          <div class="text-4xl mb-5">{s.icon}</div>
          <h3 class="text-2xl font-bold mb-1">{s.name}</h3>
          <p class={`text-sm font-semibold mb-4 ${s.featured ? 'text-[#4f8ef7]' : 'text-white/40'}`}>{s.tagline}</p>
          <p class="text-white/60 text-sm leading-relaxed mb-6 flex-1">{s.desc}</p>
          <ul class="space-y-2 mb-8">
            {s.features.map(f => (
              <li class="flex items-center gap-2 text-sm text-white/70">
                <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${s.featured ? 'bg-[#4f8ef7]' : 'bg-white/30'}`}></span>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contact"
            class={`text-center py-3 rounded-lg text-sm font-bold transition-all ${s.featured
              ? 'bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white hover:opacity-90'
              : 'border border-white/20 text-white hover:border-white/40'}`}>
            {s.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WORK -->
<section class="py-24 px-6 bg-[#0c1220]" id="work">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">Portfolio</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Recent builds</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">Real projects. Real results. All built with our AI-accelerated process.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {work.map(w => (
        <a href={w.url} target="_blank" rel="noopener"
          class="group block bg-white/4 border border-white/10 hover:border-[#4f8ef7]/40 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-[#4f8ef7]/10">
          <div class="h-48 overflow-hidden">
            <img src={w.img} alt={w.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-6">
            <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-wider mb-1">{w.type}</p>
            <h3 class="text-lg font-bold mb-2 group-hover:text-[#4f8ef7] transition-colors">{w.name}</h3>
            <p class="text-white/40 text-xs">{w.result}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <p class="text-white/40 text-sm">More projects available on request · <a href="#contact" class="text-[#4f8ef7] hover:underline">Get in touch</a></p>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="py-24 px-6" id="process">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">How It Works</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Simple. Fast. No drama.</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">Our process is built to move quickly without cutting corners.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {process.map((p, i) => (
        <div class="flex gap-5 p-6 bg-white/4 border border-white/10 rounded-2xl hover:border-white/20 transition-colors">
          <div class="text-4xl font-bold text-white/10 flex-shrink-0 leading-none">{p.step}</div>
          <div>
            <h3 class="text-lg font-bold mb-2">{p.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PRICING TEASER -->
<section class="py-24 px-6 bg-[#0c1220]">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">Pricing</p>
    <h2 class="text-4xl md:text-5xl font-bold mb-4">Transparent pricing.</h2>
    <p class="text-white/50 text-lg mb-12 max-w-xl mx-auto">No surprise invoices. No hourly billing games. Clear scope, clear price.</p>

    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      {[
        { name: 'Starter', price: '$1,500', desc: 'Single page or simple brochure site. Perfect for getting online fast.', pages: '1–3 pages', delivery: '3–5 days' },
        { name: 'Professional', price: '$2,500', desc: 'Full multi-page site with SEO, performance optimization, and contact forms.', pages: '5–10 pages', delivery: '5–7 days', popular: true },
        { name: 'Premium', price: '$4,500+', desc: 'Complex builds — e-commerce, booking systems, custom integrations.', pages: 'Unlimited', delivery: '10–14 days' },
      ].map(p => (
        <div class={`rounded-2xl p-6 text-left ${p.popular ? 'bg-gradient-to-br from-[#4f8ef7]/20 to-[#7c3aed]/20 border border-[#4f8ef7]/40' : 'bg-white/4 border border-white/10'}`}>
          {p.popular && <p class="text-[#4f8ef7] text-xs font-bold uppercase tracking-widest mb-3">Most Popular</p>}
          <h3 class="font-bold text-lg mb-1">{p.name}</h3>
          <p class="text-3xl font-bold mb-3">{p.price}</p>
          <p class="text-white/50 text-sm mb-4 leading-relaxed">{p.desc}</p>
          <div class="space-y-1.5 text-xs text-white/40">
            <p>📄 {p.pages}</p>
            <p>⚡ {p.delivery} delivery</p>
          </div>
        </div>
      ))}
    </div>
    <p class="text-white/30 text-sm">All plans include: hosting setup, domain config, mobile optimization, basic SEO, 30-day support.</p>
  </div>
</section>

<!-- FAQ -->
<section class="py-24 px-6" id="faq">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">FAQ</p>
      <h2 class="text-4xl font-bold">Common questions</h2>
    </div>
    <div class="space-y-3" id="faq-list">
      {faqs.map((f, i) => (
        <div class="bg-white/4 border border-white/10 rounded-xl overflow-hidden faq-item">
          <button class="w-full text-left px-6 py-5 flex items-center justify-between gap-4 faq-btn">
            <span class="font-semibold text-sm md:text-base">{f.q}</span>
            <svg class="w-5 h-5 text-white/40 flex-shrink-0 faq-icon transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14"/>
            </svg>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
            <p class="px-6 pb-5 text-white/50 text-sm leading-relaxed">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT / CTA -->
<section class="py-24 px-6 bg-[#0c1220]" id="contact">
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-start">
    <div>
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">Let's Build</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Ready to get started?</h2>
      <p class="text-white/50 text-lg leading-relaxed mb-8">
        Tell us about your project. We'll respond within 24 hours with a clear plan and honest pricing.
      </p>
      <div class="space-y-4 text-sm text-white/40">
        <div class="flex items-center gap-3"><span class="text-green-400">✓</span> No commitment — just a conversation</div>
        <div class="flex items-center gap-3"><span class="text-green-400">✓</span> Clear scope and pricing upfront</div>
        <div class="flex items-center gap-3"><span class="text-green-400">✓</span> Most projects delivered in under 2 weeks</div>
        <div class="flex items-center gap-3"><span class="text-green-400">✓</span> You own 100% of everything we build</div>
      </div>
    </div>

    <form class="bg-white/4 border border-white/10 rounded-2xl p-8 space-y-4"
      action="https://formspree.io/f/consultably" method="POST">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold uppercase tracking-widest text-white/40 mb-2">Name *</label>
          <input type="text" name="name" required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-[#4f8ef7]/60 transition-colors"
            placeholder="Your name" />
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-widest text-white/40 mb-2">Email *</label>
          <input type="email" name="email" required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-[#4f8ef7]/60 transition-colors"
            placeholder="you@company.com" />
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold uppercase tracking-widest text-white/40 mb-2">Service *</label>
        <select name="service" required
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white/60 focus:outline-none focus:border-[#4f8ef7]/60 transition-colors">
          <option value="">Select a service...</option>
          <option>AI Website Build</option>
          <option>Digital Marketing</option>
          <option>IT Consulting</option>
          <option>Full Package</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold uppercase tracking-widest text-white/40 mb-2">Tell us about your project *</label>
        <textarea name="message" required rows="4"
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-[#4f8ef7]/60 transition-colors resize-none"
          placeholder="What are you building? What's your timeline? What's your budget range?"></textarea>
      </div>
      <button type="submit"
        class="w-full bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white py-4 rounded-lg font-bold text-sm uppercase tracking-widest transition-opacity">
        Send Message →
      </button>
      <p class="text-white/20 text-xs text-center">We respond within 24 hours. Usually much faster.</p>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer class="py-10 px-6 border-t border-white/5">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] rounded-lg flex items-center justify-center text-white font-bold text-xs">C</div>
      <span class="font-bold text-sm">Consultably</span>
      <span class="text-white/20 text-xs ml-2">© {new Date().getFullYear()} All rights reserved.</span>
    </div>
    <div class="flex gap-6 text-xs text-white/30">
      <a href="#services" class="hover:text-white transition-colors">Services</a>
      <a href="#work" class="hover:text-white transition-colors">Work</a>
      <a href="#contact" class="hover:text-white transition-colors">Contact</a>
    </div>
  </div>
</footer>

<!-- Favicon SVG -->
<svg xmlns="http://www.w3.org/2000/svg" style="display:none">
  <symbol id="logo-icon" viewBox="0 0 32 32">
    <rect width="32" height="32" rx="8" fill="url(#g)"/>
    <defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#4f8ef7"/><stop offset="100%" stop-color="#7c3aed"/></linearGradient></defs>
    <text x="16" y="22" text-anchor="middle" font-family="sans-serif" font-weight="bold" font-size="16" fill="white">C</text>
  </symbol>
</svg>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const icon = item.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';
      
      // Close all
      document.querySelectorAll('.faq-answer').forEach((a: Element) => { (a as HTMLElement).style.maxHeight = '0px'; });
      document.querySelectorAll('.faq-icon').forEach((i: Element) => { (i as HTMLElement).style.transform = ''; });
      
      if (!isOpen) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>

</body>
</html>
