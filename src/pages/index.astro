---
import '../styles/global.css';

const plans = [
  {
    name: 'Starter',
    price: '$179',
    firstMonth: '$399',
    period: '/mo',
    desc: 'Perfect for small businesses that need a professional web presence managed hands-free.',
    features: [
      '1 website included',
      '10 AI content updates/mo',
      'Text or email to update',
      'Preview before publish',
      'Hosting on Cloudflare CDN',
      'Email support',
    ],
    cta: 'Get Started',
    popular: false,
  },
  {
    name: 'Growth',
    price: '$299',
    firstMonth: '$599',
    period: '/mo',
    desc: 'For growing businesses that want unlimited updates and better visibility online.',
    features: [
      '1 website included',
      'Unlimited AI content updates',
      'Text or email to update',
      'SEO dashboard access',
      'Monthly performance report',
      'Priority support',
    ],
    cta: 'Get Started',
    popular: true,
  },
  {
    name: 'Pro',
    price: '$449',
    firstMonth: '$899',
    period: '/mo',
    desc: 'Manage multiple locations or properties with a dedicated support team.',
    features: [
      'Up to 3 websites',
      'Unlimited AI content updates',
      'Custom integrations',
      'Weekly strategy call',
      'Phone support',
      'Analytics dashboard',
    ],
    cta: 'Get Started',
    popular: false,
  },
  {
    name: 'Concierge',
    price: '$899',
    firstMonth: '$1,199',
    period: '/mo',
    desc: 'Full-service digital presence management. We handle everything.',
    features: [
      'Unlimited websites',
      'Unlimited AI content updates',
      'Full digital marketing',
      'Dedicated account manager',
      'Daily update monitoring',
      'Custom everything',
    ],
    cta: 'Contact Us',
    popular: false,
  },
];

const steps = [
  { num: '01', icon: '🏗️', title: 'We Build Your Site', desc: 'We design and build your website in 5–7 days. Real content, real images, fully custom — no templates.' },
  { num: '02', icon: '📱', title: 'You Text the Changes', desc: 'Need to update your hours? Add a new menu item? Change a photo? Just text or email us what you want.' },
  { num: '03', icon: '🤖', title: 'AI Drafts the Update', desc: 'Our AI generates the change and sends you a preview link so you can see exactly what it looks like.' },
  { num: '04', icon: '✅', title: 'You Approve & It Goes Live', desc: 'Reply YES to publish. Reply NO to scrap it. Reply UNDO to roll back. You\'re always in control.' },
  { num: '05', icon: '🔄', title: 'Repeat Forever', desc: 'Your site stays fresh, accurate, and up-to-date — automatically. No agency, no dev, no hassle.' },
];

const categories = [
  'Restaurants & Cafes', 'Marinas & Charters', 'Salons & Spas', 'Real Estate', 'Medical & Dental',
  'Law Firms', 'Contractors', 'Retail Shops', 'Hotels & B&Bs', 'Fitness Studios',
];

const faqs = [
  { q: 'How do I send updates to my site?', a: 'Text or email your request in plain English — "Update our hours to Mon-Sat 9am-8pm" or "Add our new summer menu." The AI handles the rest.' },
  { q: 'What kind of changes can I make?', a: 'Any content update: hours, photos, pricing, new pages, events, menus, team members, promotions. If it\'s on your site, you can update it.' },
  { q: 'How long does the initial build take?', a: 'Most websites are live within 5–7 business days. More complex sites with custom features may take up to 2 weeks.' },
  { q: 'What if I don\'t like a change?', a: 'Before anything goes live, you\'ll get a preview link. Reply NO and the change is discarded. Already live? Reply UNDO and we roll it back instantly.' },
  { q: 'Can I cancel anytime?', a: 'Yes. No long-term contracts. Cancel anytime with 30 days notice. Your site and code are yours to keep.' },
  { q: 'What\'s the difference between plans?', a: 'The main differences are the number of sites you can manage and your level of support. All plans include unlimited text/email updates except Starter (10/mo).' },
  { q: 'Do I own my website?', a: 'Yes, 100%. The code, the domain, the content — all yours. We just manage and host it.' },
  { q: 'What does the first month cost?', a: 'The first month is higher because it includes your website build. After that, you pay the standard monthly rate.' },
];

const work = [
  { name: "Robbie's Marina", type: 'Tourism & Hospitality', url: 'https://robbies-marina-web-project.pages.dev', img: 'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&q=80&auto=format&fit=crop' },
  { name: 'Ciao Bella Islamorada', type: 'Salon & Day Spa', url: 'https://ciaobella-web.pages.dev', img: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&q=80&auto=format&fit=crop' },
  { name: "Smith's Plumbing", type: 'Trades & Services', url: 'https://smiths-plumbing-site.pages.dev', img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80&auto=format&fit=crop' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Consultably — We build your website and keep it updated forever via text or email. AI-powered. No agency. No developer. From $179/mo." />
  <title>Consultably | AI Website Management for Local Businesses</title>
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Space Grotesk', sans-serif; }
    .gradient-text { background: linear-gradient(135deg, #4f8ef7, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .gradient-btn { background: linear-gradient(135deg, #4f8ef7, #7c3aed); }
    .gradient-btn:hover { opacity: 0.9; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body class="bg-[#080c14] text-white">

<!-- NAV -->
<header class="fixed top-0 left-0 right-0 z-50 bg-[#080c14]/90 backdrop-blur-md border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <div class="w-8 h-8 gradient-btn rounded-lg flex items-center justify-center font-bold text-sm">C</div>
      <span class="font-bold text-lg">Consultably</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {[['How It Works','#how-it-works'],['Pricing','#pricing'],['Work','#work'],['FAQ','#faq']].map(([l,h]) => (
        <a href={h} class="text-white/60 hover:text-white text-sm font-medium transition-colors">{l}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href="mailto:hello@consultably.co" class="hidden sm:block text-white/50 hover:text-white text-sm transition-colors">hello@consultably.co</a>
      <a href="#pricing" class="gradient-btn text-white px-5 py-2 rounded-lg text-sm font-semibold transition-opacity">See Plans</a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(rgba(79,142,247,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(79,142,247,0.15) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-[#4f8ef7]/15 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-[#7c3aed]/15 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 text-xs font-semibold text-white/60 mb-7">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
      Now serving Florida Keys · South Florida · and beyond
    </div>

    <h1 class="text-5xl md:text-7xl font-bold mb-5 leading-[1.05] tracking-tight">
      Your website,<br />
      <span class="gradient-text">managed by AI</span>
    </h1>

    <p class="text-white/60 text-lg md:text-xl mb-4 max-w-2xl mx-auto leading-relaxed">
      We build your site in 5–7 days. Then you manage it forever by text or email. AI handles every update — no agency, no developer, no hassle.
    </p>

    <p class="text-white/40 text-base mb-10">
      Starting at <span class="text-white font-bold">$179/mo</span> after your first month build.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14">
      <a href="#pricing" class="gradient-btn text-white px-8 py-4 rounded-lg font-bold text-base transition-opacity shadow-lg shadow-[#4f8ef7]/20">
        See Pricing & Plans →
      </a>
      <a href="#how-it-works" class="border border-white/20 hover:border-white/40 text-white px-8 py-4 rounded-lg font-semibold text-base transition-colors">
        How It Works
      </a>
    </div>

    <!-- Demo update flow -->
    <div class="max-w-lg mx-auto bg-white/4 border border-white/10 rounded-2xl p-5 text-left">
      <p class="text-white/30 text-xs font-semibold uppercase tracking-widest mb-3">Example update</p>
      <div class="space-y-3">
        <div class="flex gap-3">
          <div class="w-7 h-7 bg-blue-500/20 rounded-full flex items-center justify-center text-xs flex-shrink-0 mt-0.5">👤</div>
          <div class="bg-white/8 rounded-xl rounded-tl-none px-4 py-2.5 text-sm text-white/80">"Update our hours — we're now open Sundays 10am to 6pm"</div>
        </div>
        <div class="flex gap-3 justify-end">
          <div class="bg-[#4f8ef7]/20 rounded-xl rounded-tr-none px-4 py-2.5 text-sm text-white/80">Done! Preview: <span class="text-[#4f8ef7] underline">preview.yoursite.com/hours</span> — reply YES to publish or NO to cancel</div>
          <div class="w-7 h-7 bg-[#4f8ef7]/20 rounded-full flex items-center justify-center text-xs flex-shrink-0 mt-0.5">🤖</div>
        </div>
        <div class="flex gap-3">
          <div class="w-7 h-7 bg-blue-500/20 rounded-full flex items-center justify-center text-xs flex-shrink-0 mt-0.5">👤</div>
          <div class="bg-white/8 rounded-xl rounded-tl-none px-4 py-2.5 text-sm text-white/80">"YES"</div>
        </div>
        <div class="flex gap-3 justify-end">
          <div class="bg-green-500/15 rounded-xl rounded-tr-none px-4 py-2.5 text-sm text-green-300">✅ Live! Your hours are updated on your website.</div>
          <div class="w-7 h-7 bg-[#4f8ef7]/20 rounded-full flex items-center justify-center text-xs flex-shrink-0 mt-0.5">🤖</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHO IT'S FOR -->
<section class="py-12 px-6 bg-white/2 border-y border-white/5">
  <div class="max-w-5xl mx-auto text-center">
    <p class="text-white/30 text-xs font-semibold uppercase tracking-widest mb-5">Built for local businesses in every category</p>
    <div class="flex flex-wrap justify-center gap-2">
      {categories.map(c => (
        <span class="bg-white/5 border border-white/10 text-white/60 text-xs font-medium px-3 py-1.5 rounded-full">{c}</span>
      ))}
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="py-24 px-6" id="how-it-works">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">The Process</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Simple. Fast. No drama.</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">You text. AI updates. Your site stays current forever.</p>
    </div>
    <div class="space-y-4">
      {steps.map((s, i) => (
        <div class="flex gap-6 items-start p-6 bg-white/3 border border-white/8 rounded-2xl hover:border-[#4f8ef7]/30 transition-all duration-300 card-hover fade-in">
          <div class="text-4xl flex-shrink-0">{s.icon}</div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-white/20 font-bold text-sm">{s.num}</span>
              <h3 class="text-lg font-bold">{s.title}</h3>
            </div>
            <p class="text-white/50 text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="py-24 px-6 bg-[#0c1220]" id="pricing">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">Pricing</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">One price. Everything included.</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">First month includes your website build. After that, just the monthly management fee.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {plans.map(p => (
        <div class={`relative rounded-2xl p-7 flex flex-col card-hover fade-in transition-all duration-300 ${p.popular ? 'bg-gradient-to-br from-[#4f8ef7]/20 to-[#7c3aed]/20 border-2 border-[#4f8ef7]/50' : 'bg-white/4 border border-white/10'}`}>
          {p.popular && <div class="absolute -top-3 left-1/2 -translate-x-1/2 gradient-btn text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest">Most Popular</div>}
          <h3 class="font-bold text-lg mb-1">{p.name}</h3>
          <div class="mb-1">
            <span class="text-3xl font-bold">{p.price}</span>
            <span class="text-white/40 text-sm">{p.period}</span>
          </div>
          <p class="text-white/30 text-xs mb-4">First month: <span class="text-[#4f8ef7]">{p.firstMonth}</span> (includes build)</p>
          <p class="text-white/50 text-xs leading-relaxed mb-5 flex-1">{p.desc}</p>
          <ul class="space-y-2 mb-6">
            {p.features.map(f => (
              <li class="flex items-center gap-2 text-xs text-white/70">
                <span class="w-1.5 h-1.5 rounded-full bg-[#4f8ef7] flex-shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
          <a href="mailto:hello@consultably.co?subject=I'm interested in the " + p.name + " plan"
            class={`text-center py-3 rounded-lg text-sm font-bold transition-all ${p.popular ? 'gradient-btn text-white hover:opacity-90' : 'border border-white/20 text-white hover:border-white/40'}`}>
            {p.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="bg-white/3 border border-white/8 rounded-2xl p-6 text-center">
      <p class="text-white/40 text-sm">All plans include: Custom-built website · Cloudflare CDN hosting · SSL certificate · Mobile optimized · SEO-ready · 30-day rollback history</p>
    </div>
  </div>
</section>

<!-- WORK -->
<section class="py-24 px-6" id="work">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">Recent Builds</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">See what we build</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">Every site is custom-built, fast, and beautiful. These went live in under a week.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {work.map(w => (
        <a href={w.url} target="_blank" rel="noopener"
          class="group block bg-white/4 border border-white/10 hover:border-[#4f8ef7]/40 rounded-2xl overflow-hidden card-hover transition-all duration-300 fade-in">
          <div class="h-48 overflow-hidden">
            <img src={w.img} alt={w.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-wider mb-1">{w.type}</p>
            <h3 class="font-bold group-hover:text-[#4f8ef7] transition-colors">{w.name}</h3>
            <p class="text-white/30 text-xs mt-1">View live site →</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-24 px-6 bg-[#0c1220]" id="faq">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-[#4f8ef7] text-xs font-semibold uppercase tracking-[0.3em] mb-3">FAQ</p>
      <h2 class="text-4xl font-bold">Common questions</h2>
    </div>
    <div class="space-y-3" id="faq-list">
      {faqs.map(f => (
        <div class="bg-white/4 border border-white/10 rounded-xl overflow-hidden faq-item">
          <button class="w-full text-left px-6 py-5 flex items-center justify-between gap-4 faq-btn hover:bg-white/2 transition-colors">
            <span class="font-semibold text-sm md:text-base">{f.q}</span>
            <svg class="w-5 h-5 text-white/30 flex-shrink-0 faq-icon transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14"/>
            </svg>
          </button>
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
            <p class="px-6 pb-5 text-white/50 text-sm leading-relaxed">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-4xl md:text-5xl font-bold mb-4">Ready to get started?</h2>
    <p class="text-white/50 text-lg mb-8">Email us your business name and category. We'll send you a brief form and have your site live within a week.</p>
    <a href="mailto:hello@consultably.co?subject=I want a website"
      class="gradient-btn text-white px-10 py-4 rounded-lg font-bold text-lg inline-block transition-opacity shadow-xl shadow-[#4f8ef7]/20 hover:opacity-90">
      Email Us to Get Started →
    </a>
    <p class="text-white/30 text-sm mt-4">Or text <span class="text-white">(555) 000-0000</span> · We respond same day</p>
  </div>
</section>

<!-- FOOTER -->
<footer class="py-10 px-6 border-t border-white/5">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 gradient-btn rounded-lg flex items-center justify-center font-bold text-xs">C</div>
      <span class="font-bold">Consultably</span>
      <span class="text-white/20 text-xs ml-2">© {new Date().getFullYear()}</span>
    </div>
    <div class="flex gap-6 text-xs text-white/30">
      <a href="#how-it-works" class="hover:text-white transition-colors">How It Works</a>
      <a href="#pricing" class="hover:text-white transition-colors">Pricing</a>
      <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
      <a href="mailto:hello@consultably.co" class="hover:text-white transition-colors">hello@consultably.co</a>
    </div>
  </div>
</footer>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';
      document.querySelectorAll('.faq-answer').forEach(a => a.style.maxHeight = '0px');
      document.querySelectorAll('.faq-icon').forEach(i => i.style.transform = '');
      if (!isOpen) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
      }
    });
  });

  // Scroll reveal
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>

</body>
</html>
