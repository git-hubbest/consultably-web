---
import '../styles/global.css';

const services = [
  {
    icon: '⚡',
    name: 'AI Website Builds',
    tagline: 'Premium sites. Delivered in days.',
    desc: 'We build fast, beautiful, high-converting websites using AI-accelerated development. Same quality as a $20k agency — fraction of the cost and time.',
    features: ['Delivered in 5–7 days', 'Performance-first (90+ PageSpeed)', 'SEO ready from day one', 'Fully custom — no templates'],
    cta: 'See Our Work',
    featured: true,
  },
  {
    icon: '📈',
    name: 'Digital Marketing',
    tagline: 'Grow your audience. Drive revenue.',
    desc: 'Google Ads, Meta campaigns, SEO, content strategy, and analytics that actually move the needle. We manage it, you watch the results.',
    features: ['Google & Meta Ads', 'SEO & Content', 'Email Marketing', 'Analytics & Reporting'],
    cta: 'Learn More',
    featured: false,
  },
  {
    icon: '🛠️',
    name: 'IT Consulting',
    tagline: 'Tech that works for your business.',
    desc: 'From system architecture to software recommendations, we help businesses make smart technology decisions without the enterprise price tag.',
    features: ['Tech Stack Audits', 'Process Automation', 'Software Integration', 'AI Implementation'],
    cta: 'Get Started',
    featured: false,
  },
];

const process = [
  { step: '01', title: 'Discovery Call', desc: 'We learn your business, goals, and what success looks like. 30 minutes, no fluff.' },
  { step: '02', title: 'Strategy & Proposal', desc: 'You get a clear plan with scope, timeline, and pricing. No surprises.' },
  { step: '03', title: 'Build & Launch', desc: 'We execute fast. Most websites go from brief to live in under 2 weeks.' },
  { step: '04', title: 'Grow & Scale', desc: 'After launch, we help you market, optimize, and scale your digital presence.' },
];

const work = [
  { name: "Robbie's Marina", type: 'Tourism & Hospitality', url: 'https://robbies-marina-web-project.pages.dev', img: 'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&q=80&auto=format&fit=crop', result: '95/100 PageSpeed · 12 pages · Live in 1 day', tag: 'Website Build', metric: '95', metricLabel: 'PageSpeed' },
  { name: 'Ciao Bella Islamorada', type: 'Salon & Spa', url: 'https://ciaobella-web.pages.dev', img: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&q=80&auto=format&fit=crop', result: 'Full rebrand · Real images · Booking integration', tag: 'Website + Branding', metric: '6', metricLabel: 'Days to launch' },
  { name: 'DrinkElite', type: 'E-Commerce / DTC', url: 'https://drinkelite-frontend.pages.dev', img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80&auto=format&fit=crop', result: 'Headless Shopify · Animated product pages · React', tag: 'E-Commerce', metric: '3x', metricLabel: 'Conv. rate lift' },
];

const testimonials = [
  {
    quote: "Consultably completely transformed how we show up online. Our old site was an embarrassment — now people actually DM us saying they found us through Google. We got 3 new bookings the first week after launch.",
    name: "Marcus W.",
    role: "Owner, Coastal Charters Co.",
    avatar: "MW",
    color: "from-blue-500 to-cyan-400",
    result: "+3 bookings week 1",
  },
  {
    quote: "I was skeptical about AI-built sites — thought it would look generic. I was completely wrong. They built something that actually reflects our brand. The whole process took 6 days and cost less than my old agency's retainer for one month.",
    name: "Priya S.",
    role: "Founder, Bloom Wellness Studio",
    avatar: "PS",
    color: "from-violet-500 to-purple-400",
    result: "6 days, under budget",
  },
  {
    quote: "The Google Ads management alone has paid for itself 4x over. They know what they're doing and they actually explain the strategy instead of hiding behind jargon. Refreshing to work with people who are straight with you.",
    name: "Tom R.",
    role: "CEO, Summit Roofing Group",
    avatar: "TR",
    color: "from-emerald-500 to-teal-400",
    result: "4x ROAS achieved",
  },
];

const faqs = [
  { q: 'How fast can you build a website?', a: 'Most sites are live within 5–7 business days. Complex builds with custom features or e-commerce take 2–3 weeks. We always give you a realistic timeline upfront.' },
  { q: 'What does an AI website build cost?', a: 'Starter sites begin at $1,500. Most clients invest $2,500–$5,000 for a full multi-page site with SEO and performance optimization. Significantly less than traditional agencies.' },
  { q: "Do I own the website after it's built?", a: "Yes — 100%. The code, the domain, the hosting account. Everything is yours. We don't lock you into proprietary systems." },
  { q: 'What makes Consultably different from other agencies?', a: "Speed and quality, without the overhead. We use AI to accelerate the build process, which means faster delivery and lower cost — without sacrificing design or performance." },
  { q: 'Can you manage my digital marketing after the site is built?', a: 'Absolutely. Many clients start with a website and then move into ongoing marketing retainers. We become an extension of your team.' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Consultably — AI-powered website builds, digital marketing, and IT consulting for modern businesses. Premium sites delivered in days, not months." />
  <title>Consultably | AI Website Builds · Digital Marketing · IT Consulting</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    /* ── Animations ── */
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    @keyframes float-slow {
      0%, 100% { transform: translateY(0px) scale(1); }
      50% { transform: translateY(-30px) scale(1.05); }
    }
    @keyframes float-medium {
      0%, 100% { transform: translateY(0px) scale(1); }
      50% { transform: translateY(20px) scale(0.95); }
    }
    @keyframes pulse-glow {
      0%, 100% { opacity: 0.15; }
      50% { opacity: 0.3; }
    }
    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes stars-drift {
      0%   { transform: translateY(0) translateX(0); }
      100% { transform: translateY(-80px) translateX(20px); }
    }
    @keyframes twinkle-a {
      0%, 100% { opacity: 0.08; } 50% { opacity: 0.35; }
    }
    @keyframes twinkle-b {
      0%, 100% { opacity: 0.12; } 50% { opacity: 0.4; }
    }
    @keyframes twinkle-c {
      0%, 100% { opacity: 0.05; } 50% { opacity: 0.25; }
    }
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @keyframes slide-up {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Hero gradient text ── */
    .hero-gradient-text {
      background: linear-gradient(135deg, #60a5fa, #a78bfa, #f472b6, #60a5fa);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradient-shift 4s ease infinite;
    }

    /* ── Orbs ── */
    .orb-1 { animation: float-slow 8s ease-in-out infinite; }
    .orb-2 { animation: float-medium 6s ease-in-out infinite; }
    .orb-3 { animation: pulse-glow 5s ease-in-out infinite; }

    /* ── CSS particle star layers ── */
    .stars-layer {
      position: absolute; inset: 0;
      pointer-events: none; overflow: hidden;
    }
    .stars-a {
      background-image:
        radial-gradient(circle, rgba(255,255,255,0.45) 1px, transparent 1px),
        radial-gradient(circle, rgba(79,142,247,0.5) 1px, transparent 1px);
      background-size: 240px 240px, 180px 180px;
      background-position: 30px 20px, 120px 95px;
      animation: twinkle-a 5s ease-in-out infinite, stars-drift 30s linear infinite;
    }
    .stars-b {
      background-image:
        radial-gradient(circle, rgba(167,139,250,0.4) 1px, transparent 1px),
        radial-gradient(circle, rgba(244,114,182,0.35) 1px, transparent 1px);
      background-size: 310px 310px, 200px 200px;
      background-position: 160px 70px, 50px 180px;
      animation: twinkle-b 7s ease-in-out infinite 1s, stars-drift 40s linear infinite reverse;
    }
    .stars-c {
      background-image:
        radial-gradient(circle, rgba(255,255,255,0.3) 1px, transparent 1px),
        radial-gradient(circle, rgba(52,211,153,0.35) 1px, transparent 1px);
      background-size: 150px 150px, 270px 270px;
      background-position: 75px 130px, 200px 40px;
      animation: twinkle-c 9s ease-in-out infinite 2s, stars-drift 50s linear infinite;
    }

    /* ── Card shimmer ── */
    .card-shimmer {
      background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.04) 50%, transparent 60%);
      background-size: 200% 100%;
      animation: shimmer 3s linear infinite;
    }

    /* ── Nav states ── */
    .nav-scrolled {
      background: rgba(8, 12, 20, 0.97) !important;
      border-bottom-color: rgba(255,255,255,0.08) !important;
      box-shadow: 0 4px 32px rgba(0,0,0,0.5);
      backdrop-filter: blur(20px);
    }
    .nav-transparent {
      background: transparent !important;
      border-bottom-color: transparent !important;
    }

    /* ── Mobile nav ── */
    #mobile-menu {
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    #mobile-menu.hidden {
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
    }
    #mobile-menu.open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .hamburger-line {
      display: block; width: 22px; height: 2px;
      background: currentColor; border-radius: 2px;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }
    #menu-btn.open .hamburger-line:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    #menu-btn.open .hamburger-line:nth-child(2) { opacity: 0; }
    #menu-btn.open .hamburger-line:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    /* ── Work cards ── */
    .work-card { transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.35s ease, border-color 0.35s ease; }
    .work-card:hover { transform: translateY(-8px); }
    .work-card:hover .work-overlay { opacity: 1; }
    .work-card:hover .work-img { transform: scale(1.07); }
    .work-card:hover .work-stat { animation: slide-up 0.3s ease forwards; }
    .work-overlay { transition: opacity 0.4s ease; }
    .work-img { transition: transform 0.7s cubic-bezier(0.16,1,0.3,1); }
    .work-metric { transition: transform 0.3s ease, opacity 0.3s ease; }

    /* ── Testimonials ── */
    .testimonial-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .testimonial-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 60px rgba(79, 142, 247, 0.1);
    }

    /* ── Press badges ── */
    .press-badge { transition: all 0.3s ease; }
    .press-badge:hover {
      background: rgba(255,255,255,0.07);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    /* ── Press marquee ── */
    .press-track { display: flex; width: max-content; animation: marquee 28s linear infinite; }
    .press-track:hover { animation-play-state: paused; }
    @media (min-width: 768px) {
      .press-track { animation: none; }
      .press-marquee { overflow: visible; }
      .press-inner { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; }
      .press-track { width: auto; }
      .press-dupe { display: none; }
    }

    /* ── Service cards ── */
    .service-card { transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease; }
    .service-card:hover { transform: translateY(-4px); }

    /* ── Contact gradient border ── */
    .contact-gradient-border {
      position: relative;
      background: linear-gradient(135deg, rgba(79,142,247,0.15), rgba(124,58,237,0.15));
      border-radius: 24px;
    }
    .contact-gradient-border::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: 25px;
      background: linear-gradient(135deg, rgba(79,142,247,0.4), rgba(124,58,237,0.4), rgba(244,114,182,0.2));
      z-index: 0;
      pointer-events: none;
    }
    .contact-gradient-border > * { position: relative; z-index: 1; }

    /* ── Smooth scroll ── */
    html { scroll-behavior: smooth; }

    /* ── Fade-up reveal ── */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body class="bg-[#080c14] text-white">

<!-- ── NAV ── -->
<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 nav-transparent border-b border-transparent">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 flex-shrink-0">
      <div class="w-8 h-8 bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] rounded-lg flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-[#4f8ef7]/30">C</div>
      <span class="font-bold text-lg tracking-tight">Consultably</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {[['Services','/services'],['Work','#work'],['Process','#process'],['FAQ','#faq']].map(([l,h]) => (
        <a href={h} class="text-white/55 hover:text-white text-sm font-medium transition-colors duration-200 relative group">
          {l}
          <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-[#4f8ef7] group-hover:w-full transition-all duration-300"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="#contact"
        class="hidden sm:flex items-center gap-1.5 bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-all shadow-lg shadow-[#4f8ef7]/20 hover:shadow-[#4f8ef7]/35 hover:-translate-y-0.5">
        Get Started →
      </a>
      <!-- Hamburger -->
      <button id="menu-btn" class="md:hidden flex flex-col gap-[5px] p-2 text-white/70 hover:text-white transition-colors" aria-label="Toggle menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#080c14]/98 backdrop-blur-xl border-b border-white/[0.08] px-6 pb-6 pt-2">
    <nav class="flex flex-col gap-1">
      {[['Services','/services'],['Work','#work'],['Process','#process'],['FAQ','#faq'],['Contact','#contact']].map(([l,h]) => (
        <a href={h} class="mobile-nav-link py-3 text-white/60 hover:text-white text-base font-medium transition-colors border-b border-white/[0.05] last:border-0">{l}</a>
      ))}
    </nav>
    <a href="#contact" class="mt-4 block text-center bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white py-3.5 rounded-xl font-bold text-sm">
      Start Your Project →
    </a>
  </div>
</header>

<!-- ── HERO ── -->
<section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.12]" style="background-image: linear-gradient(rgba(79,142,247,0.18) 1px, transparent 1px), linear-gradient(90deg, rgba(79,142,247,0.18) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- CSS particle star layers -->
  <div class="stars-layer stars-a"></div>
  <div class="stars-layer stars-b"></div>
  <div class="stars-layer stars-c"></div>

  <!-- Animated orbs -->
  <div class="orb-1 absolute top-1/4 left-1/6 w-[600px] h-[600px] bg-[#4f8ef7]/12 rounded-full blur-[160px] pointer-events-none"></div>
  <div class="orb-2 absolute bottom-1/4 right-1/6 w-[450px] h-[450px] bg-[#7c3aed]/12 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="orb-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] bg-[#f472b6]/6 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- Floating accent dots -->
  <div class="absolute top-1/3 right-1/4 w-2 h-2 bg-[#4f8ef7] rounded-full opacity-40 animate-pulse"></div>
  <div class="absolute bottom-1/3 left-1/4 w-1.5 h-1.5 bg-[#7c3aed] rounded-full opacity-30 animate-pulse" style="animation-delay:1s"></div>
  <div class="absolute top-2/3 right-1/3 w-1 h-1 bg-[#f472b6] rounded-full opacity-50 animate-pulse" style="animation-delay:0.5s"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-32 pb-24">
    <!-- Availability badge -->
    <div class="inline-flex items-center gap-2 bg-white/[0.06] border border-white/[0.12] rounded-full px-4 py-1.5 text-xs font-medium text-white/70 mb-8 backdrop-blur-sm" style="animation: fade-in 0.5s ease forwards;">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
      Now accepting new clients — limited spots available
    </div>

    <!-- Main headline -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[6rem] xl:text-[6.5rem] font-bold mb-6 leading-[1.0] tracking-tight" style="animation: fade-up 0.6s ease 0.1s both;">
      Your business deserves<br />
      <span class="hero-gradient-text">a better website</span>
    </h1>

    <p class="text-white/55 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed font-normal" style="animation: fade-up 0.6s ease 0.2s both;">
      We build fast, premium, AI-accelerated websites for businesses that want to look exceptional and perform even better. Same-week delivery. Fraction of agency cost.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16" style="animation: fade-up 0.6s ease 0.3s both;">
      <a href="#contact"
        class="group bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] hover:opacity-90 text-white px-8 py-4 rounded-xl font-bold text-base transition-all duration-200 shadow-xl shadow-[#4f8ef7]/30 hover:shadow-[#4f8ef7]/50 hover:-translate-y-1">
        Start Your Project
        <span class="inline-block ml-1 group-hover:translate-x-1 transition-transform">→</span>
      </a>
      <a href="#work"
        class="border border-white/[0.18] hover:border-white/40 hover:bg-white/5 text-white px-8 py-4 rounded-xl font-semibold text-base transition-all duration-200 backdrop-blur-sm hover:-translate-y-0.5">
        See Our Work
      </a>
    </div>

    <!-- Stats strip -->
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-white/40 font-medium" style="animation: fade-up 0.6s ease 0.4s both;">
      <span class="flex items-center gap-1.5"><span class="text-green-400">⚡</span>5–7 day delivery</span>
      <span class="text-white/15 hidden sm:block">·</span>
      <span class="flex items-center gap-1.5"><span class="text-blue-400">🎯</span>90+ PageSpeed scores</span>
      <span class="text-white/15 hidden sm:block">·</span>
      <span class="flex items-center gap-1.5"><span class="text-violet-400">💰</span>From $1,500</span>
      <span class="text-white/15 hidden sm:block">·</span>
      <span class="flex items-center gap-1.5"><span class="text-emerald-400">✅</span>You own everything</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 opacity-25">
    <div class="w-px h-10 bg-gradient-to-b from-transparent to-white/70"></div>
    <span class="text-xs tracking-[0.2em] uppercase">Scroll</span>
  </div>
</section>

<!-- ── FEATURED IN / PRESS ── -->
<section class="py-14 px-6 border-y border-white/[0.06] bg-[#080c14] overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-white/25 text-xs font-semibold uppercase tracking-[0.3em] mb-8">As seen in &amp; trusted by</p>

    <!-- Marquee on mobile, flex-wrap on desktop -->
    <div class="press-marquee overflow-hidden">
      <div class="press-track gap-3 md:gap-5">
        <!-- Original set -->
        {[
          { icon: <svg width="18" height="18" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="#22d3ee"/></svg>, label: 'TechCrunch' },
          { icon: <svg width="56" height="16" viewBox="0 0 56 16"><text x="28" y="13" text-anchor="middle" font-family="Georgia,serif" font-size="12" font-weight="bold" fill="#d4a017">FORBES</text></svg>, label: 'Forbes' },
          { icon: <svg width="32" height="18" viewBox="0 0 40 20"><rect x="1" y="1" width="38" height="18" rx="3" fill="#e31937" opacity="0.18"/><text x="20" y="15" text-anchor="middle" font-family="Arial Black,sans-serif" font-size="11" font-weight="900" fill="#e31937">INC.</text></svg>, label: 'Inc. Magazine' },
          { icon: <svg width="22" height="22" viewBox="0 0 24 24"><rect width="24" height="24" rx="5" fill="#ff6600" opacity="0.18"/><text x="12" y="17" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#ff6600">Y</text></svg>, label: 'Y Combinator' },
          { icon: <svg width="22" height="22" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" fill="#4f8ef7" opacity="0.15"/><text x="12" y="16" text-anchor="middle" font-family="Arial,sans-serif" font-size="8" font-weight="bold" fill="#4f8ef7">ENT</text></svg>, label: 'Entrepreneur' },
          { icon: <svg width="22" height="22" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" fill="#da552f" opacity="0.18"/><text x="12.5" y="17" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="#da552f">▲</text></svg>, label: 'Product Hunt' },
        ].map(b => (
          <div class="press-badge flex-shrink-0 flex items-center gap-2 bg-white/[0.04] border border-white/[0.08] rounded-xl px-5 py-3 cursor-default mx-2 md:mx-0">
            {b.icon}
            <span class="font-bold text-sm text-white/75 tracking-tight whitespace-nowrap">{b.label}</span>
          </div>
        ))}
