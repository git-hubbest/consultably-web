              <span class="text-3xl font-bold">{plan.price}</span>
              <span class="text-white/30 text-sm">/ {plan.period}</span>
            </div>
            <p class="text-white/40 text-xs leading-relaxed">{plan.desc}</p>
          </div>

          <div class="flex-1 space-y-4 mb-6">
            <div>
              <p class="text-white/25 text-[10px] uppercase tracking-widest mb-2.5 font-semibold">Includes</p>
              <ul class="space-y-2">
                {plan.features.map(f => (
                  <li class="flex items-start gap-2 text-xs text-white/65">
                    <svg class={`w-3.5 h-3.5 mt-0.5 flex-shrink-0 ${plan.highlight ? 'text-[#4f8ef7]' : 'text-green-400/70'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
            {plan.notIncluded.length > 0 && (
              <div>
                <p class="text-white/20 text-[10px] uppercase tracking-widest mb-2.5 font-semibold">Not included</p>
                <ul class="space-y-2">
                  {plan.notIncluded.map(f => (
                    <li class="flex items-start gap-2 text-xs text-white/25">
                      <svg class="w-3.5 h-3.5 mt-0.5 flex-shrink-0 text-white/15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          <a href="/#contact"
            class={`block text-center py-3 rounded-xl text-sm font-bold transition-all duration-200 hover:-translate-y-0.5 ${plan.highlight
              ? 'bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white hover:opacity-90 shadow-lg shadow-[#4f8ef7]/25'
              : 'border border-white/20 text-white hover:border-white/40 hover:bg-white/5'}`}>
            {plan.cta} →
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-white/25 text-sm">
      All website plans include: mobile optimization, performance optimization, basic SEO, and post-launch support.{' '}
      <a href="/#contact" class="text-[#4f8ef7] hover:underline">Talk to us</a> for custom requirements.
    </p>
  </div>
</section>

<!-- ── COMPARISON TABLE ── -->
