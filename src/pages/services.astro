<footer class="py-10 px-6 border-t border-white/[0.06]">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-2.5">
      <div class="w-7 h-7 bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] rounded-lg flex items-center justify-center text-white font-bold text-xs">C</div>
      <span class="font-bold text-sm">Consultably</span>
      <span class="text-white/20 text-xs ml-2">© {new Date().getFullYear()} All rights reserved.</span>
    </div>
    <div class="flex gap-6 text-xs text-white/30">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <a href="/#work" class="hover:text-white transition-colors">Work</a>
      <a href="/#contact" class="hover:text-white transition-colors">Contact</a>
    </div>
  </div>
</footer>

<script>
  // ── Nav scroll (for if user somehow gets to top) ──
  const nav = document.getElementById('main-nav') as HTMLElement;
  function updateNav() {
    if (window.scrollY > 20) {
      nav.classList.remove('nav-transparent');
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.add('nav-transparent');
      nav.classList.remove('nav-scrolled');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });

  // ── Mobile menu ──
  const menuBtn = document.getElementById('menu-btn') as HTMLElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

  menuBtn.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('open');
    if (isOpen) {
      mobileMenu.classList.remove('open');
      mobileMenu.classList.add('hidden');
      menuBtn.classList.remove('open');
    } else {
      mobileMenu.classList.remove('hidden');
      requestAnimationFrame(() => mobileMenu.classList.add('open'));
      menuBtn.classList.add('open');
    }
  });

  mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      mobileMenu.classList.add('hidden');
      menuBtn.classList.remove('open');
    });
  });

  // ── Active anchor pill highlighting ──
  const anchorPills = document.querySelectorAll('.anchor-pill');
  const sectionIds = ['websites', 'marketing', 'consulting', 'pricing'];

  function updateActivePill() {
    const scrollY = window.scrollY + 140;
    let activeId = '';

    sectionIds.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.offsetTop <= scrollY) activeId = id;
    });

    anchorPills.forEach(pill => {
      const href = (pill as HTMLAnchorElement).getAttribute('href') || '';
      if (href === `#${activeId}` || href === '#pricing' && activeId === 'pricing') {
        pill.classList.add('active');
      } else {
        pill.classList.remove('active');
      }
    });
  }

  window.addEventListener('scroll', updateActivePill, { passive: true });
  updateActivePill();

  // ── FAQ accordion ──
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const icon = item.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';

      const parentList = item.parentElement;
      if (parentList) {
        parentList.querySelectorAll('.faq-answer').forEach((a: Element) => { (a as HTMLElement).style.maxHeight = '0px'; });
        parentList.querySelectorAll('.faq-icon').forEach((ic: Element) => { (ic as HTMLElement).style.transform = ''; });
      }

      if (!isOpen) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
      }
    });
  });

  // ── Scroll reveal ──
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
</script>

</body>
